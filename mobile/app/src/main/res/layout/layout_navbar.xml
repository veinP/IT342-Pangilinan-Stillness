<?xml version="1.0" encoding="utf-8"?>
<!-- Stillness Mobile Navbar - Matches Web UI -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@color/white"
    android:elevation="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="24dp">

    <!-- Logo -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="sans-serif-black"
        android:text="@string/app_name"
        android:textColor="#1E3A5F"
        android:textSize="22sp"
        android:letterSpacing="-0.02" />

    <!-- Right Side Pill Style User Info -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_nav_user"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/nav_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:text="User"
            android:textColor="#1E3A5F"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_nav_logout"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="LOGOUT"
            android:textColor="@color/red_error_text"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
