<?xml version="1.0" encoding="utf-8"?>
<!-- Stillness Mobile Register - Carbon Copy of Web UI -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stillness_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="40dp">

        <!-- Logo -->
        <TextView
            android:id="@+id/tv_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/app_name"
            android:textColor="@color/stillness_blue_primary"
            android:textSize="28sp"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="32dp"/>

        <!-- Register Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingVertical="44dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Your Account"
                android:textColor="@color/text_main"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Start your wellness journey today"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginBottom="36dp"/>

            <!-- Error Banner -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_error"
                android:padding="12dp"
                android:textColor="@color/red_error_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Success Banner -->
            <TextView
                android:id="@+id/tv_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_success"
                android:padding="12dp"
                android:textColor="@color/green_success_text"
                android:textSize="14sp" android:visibility="gone" />

            <!-- Full Name Field -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Name" android:textColor="@color/text_label" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_full_name" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_edittext" android:hint="Enter your full name" android:inputType="textPersonName" android:paddingHorizontal="16dp" android:textColor="@color/text_main" android:textColorHint="@color/text_hint" android:textSize="15sp" />
            </LinearLayout>

            <!-- Email Field -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Address" android:textColor="@color/text_label" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_email" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_edittext" android:hint="Enter your email address" android:inputType="textEmailAddress" android:paddingHorizontal="16dp" android:textColor="@color/text_main" android:textColorHint="@color/text_hint" android:textSize="15sp" />
            </LinearLayout>

            <!-- Role Selection -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Account Type" android:textColor="@color/text_label" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
                <!-- User Card -->
                <LinearLayout android:id="@+id/ll_role_user" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_role_card_active" android:orientation="vertical" android:padding="12dp" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true">
                    <TextView android:id="@+id/tv_role_user_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User" android:textColor="@color/text_main" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Book sessions and manage schedule." android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
                <!-- Instructor Card -->
                <LinearLayout android:id="@+id/ll_role_instructor" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_role_card" android:orientation="vertical" android:padding="12dp" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true">
                    <TextView android:id="@+id/tv_role_instructor_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Instructor" android:textColor="@color/text_main" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Manage sessions and attendees." android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Password Field -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Password" android:textColor="@color/text_label" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="52dp">
                    <EditText android:id="@+id/et_password" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_edittext" android:hint="Enter your password" android:inputType="textPassword" android:paddingHorizontal="16dp" android:paddingEnd="48dp" android:textColor="@color/text_main" android:textColorHint="@color/text_hint" android:textSize="15sp" />
                    <ImageView android:id="@+id/iv_toggle_password" android:layout_width="36dp" android:layout_height="36dp" android:layout_gravity="end|center_vertical" android:layout_marginEnd="8dp" android:contentDescription="Toggle password" android:padding="6dp" android:src="@drawable/ic_eye_closed" />
                </FrameLayout>
                <ProgressBar android:id="@+id/pb_strength" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="8dp" android:progress="0" android:progressDrawable="@drawable/strength_meter_progress" android:visibility="gone"/>
                <TextView android:id="@+id/tv_password_hint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Min. 8 characters, 1 uppercase, 1 digit" android:textColor="@color/text_secondary" android:textSize="13sp" />
            </LinearLayout>

            <!-- Confirm Password Field -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Confirm Password" android:textColor="@color/text_label" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="52dp">
                    <EditText android:id="@+id/et_confirm_password" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_edittext" android:hint="Re-enter your password" android:inputType="textPassword" android:paddingHorizontal="16dp" android:paddingEnd="48dp" android:textColor="@color/text_main" android:textColorHint="@color/text_hint" android:textSize="15sp" />
                    <ImageView android:id="@+id/iv_toggle_confirm" android:layout_width="36dp" android:layout_height="36dp" android:layout_gravity="end|center_vertical" android:layout_marginEnd="8dp" android:contentDescription="Toggle confirm password" android:padding="6dp" android:src="@drawable/ic_eye_closed" />
                </FrameLayout>
            </LinearLayout>

            <!-- Submit -->
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_button_primary"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Divider -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="24dp">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/border_divider" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="or" android:textColor="@color/text_hint" android:textSize="13sp" android:paddingHorizontal="16dp" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/border_divider" />
            </LinearLayout>

            <!-- Google Button -->
            <LinearLayout android:id="@+id/btn_google" android:layout_width="match_parent" android:layout_height="54dp" android:background="@drawable/bg_button_google" android:gravity="center" android:orientation="horizontal" android:clickable="true" android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="G"
                    android:textColor="@color/stillness_blue_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sign up with Google" android:textColor="@color/text_main" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_register"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/stillness_blue_primary"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Footer -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Already have an account?" android:textColor="@color/text_secondary" android:textSize="14sp" />
            <TextView android:id="@+id/tv_go_login" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Login" android:textColor="@color/stillness_blue_focus" android:textSize="14sp" android:textStyle="bold" android:layout_marginStart="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
